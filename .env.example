# Copy to .env (gitignored) and fill in. Missing values are non-fatal;
# /healthz runs without any of these set.
PORT=8080
# SQLite database file (parent dir is created if missing). The container
# image defaults this to /data/capycook.db, backed by the /data volume.
DB_PATH=./data/capycook.db
# Committed data assets (USDA/FoodOn/cost/safety/FlavorGraph CSVs) the real
# deterministic services load at startup. The container image defaults this
# to /srv/data (baked into the image, read-only).
DATA_DIR=./data
DEEPSEEK_API_KEY=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com
# Hard LLM spend cap in USD, enforced in code from Phase 3 (Gate B):
# generation hard-stops and reports once cumulative spend reaches the cap.
# Cumulative spend persists in the sidecar ledger <DB_PATH>.budget.json.
LLM_BUDGET_USD=10
# Set to 1 to force the deterministic stub LLM even when DEEPSEEK_API_KEY is
# set (no key always means stub mode).
CAPYCOOK_STUB_LLM=
