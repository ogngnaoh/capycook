# Copy to .env (gitignored) and fill in. Missing values are non-fatal;
# /healthz runs without any of these set.
PORT=8080
# SQLite database file (parent dir is created if missing). The container
# image defaults this to /data/capycook.db, backed by the /data volume.
DB_PATH=./data/capycook.db
DEEPSEEK_API_KEY=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com
# Hard LLM spend cap in USD, enforced in code from Phase 3 (Gate B):
# generation hard-stops and reports once cumulative spend reaches the cap.
LLM_BUDGET_USD=10
