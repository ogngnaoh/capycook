/bin/
.env

# macOS Finder droppings
.DS_Store

# SQLite home (real operator data — never committed; privacy/pre-push guard)
data/*.db
data/*.db-*
# LLM budget sidecar (operational spend state, lives next to the db)
data/*.db.budget.json

# eval harness output (unlabeled claim exports; the versioned instruments
# live in eval/fixtures/)
eval/out/

# frontend
web/node_modules/
web/dist/*
!web/dist/.gitkeep
web/*.tsbuildinfo

# 02b oracle evidence runs (bulky screenshots/screencasts). Retain the old
# live-path rule during cleanup; the archived path is the oracle's live default.
docs/02b-behavior-contract/evidence/
docs/archive/02b-behavior-contract/evidence/
